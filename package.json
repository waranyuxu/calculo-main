{
  "name": "calculo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/ui": "~56.0.18",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.12",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-navigation-bar": "~56.0.3",
    "expo-network": "~56.0.5",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "firebase": "^12.15.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "env:check": "node scripts/with-anwa-env.js node scripts/check-firebase-env.js",
    "eas-build-pre-install": "node scripts/prepare-eas-env.js",
    "firebase:rules:deploy": "node scripts/deploy-firebase-rules.js",
    "firebase:rules:deploy:anwa": "node scripts/deploy-firebase-rules.js --env anwa",
    "build:apk": "npm run generate:questions && npx eas-cli@latest build --platform android --profile apk",
    "build:apk:local": "npm run generate:questions && npx eas-cli@latest build --platform android --profile apk --local",
    "generate:questions": "node scripts/generate-question-course.js",
    "prestart": "npm run generate:questions",
    "start": "node scripts/with-anwa-env.js expo start --port 8081",
    "prelan": "npm run generate:questions",
    "lan": "node scripts/with-anwa-env.js expo start --port 8081",
    "pretunnel": "npm run generate:questions",
    "tunnel": "node scripts/with-anwa-env.js expo start --tunnel",
    "preandroid": "npm run generate:questions",
    "android": "node scripts/with-anwa-env.js expo start --android --port 8081",
    "preios": "npm run generate:questions",
    "ios": "node scripts/with-anwa-env.js expo start --ios --port 8081",
    "preweb": "npm run generate:questions",
    "web": "node scripts/with-anwa-env.js expo start --web --port 8081",
    "lint": "node scripts/with-anwa-env.js expo lint"
  },
  "private": true
}
