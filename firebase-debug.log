[debug] [2026-06-20T14:18:33.245Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/calculo-65308/rulesets {"name":"projects/calculo-65308/rulesets/c315827b-e780-462b-a6b6-b4609d6fd9d0","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    function signedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function roomParticipant() {\n      return signedIn()\n        && ((\"hostAuthId\" in resource.data\n            && resource.data.hostAuthId == request.auth.uid)\n          || (\"guestAuthId\" in resource.data\n            && resource.data.guestAuthId == request.auth.uid)\n          || resource.data.hostId == request.auth.uid\n          || resource.data.guestId == request.auth.uid);\n    }\n\n    function validWaitingRoomJoin() {\n      return signedIn()\n        && resource.data.status == \"waiting\"\n        && request.resource.data.hostId == resource.data.hostId\n        && (!(\"hostAuthId\" in resource.data)\n          || request.resource.data.hostAuthId == resource.data.hostAuthId)\n        && request.resource.data.guestAuthId == request.auth.uid\n        && request.resource.data.status == \"playing\";\n    }\n\r\n    match /mathProgress/{userId} {\r\n      allow read, write: if signedIn() && request.auth.uid == userId;\r\n    }\r\n\r\n    match /learningStates/{userId} {\r\n      allow read: if signedIn() && request.auth.uid == userId;\r\n\r\n      allow create, update: if signedIn()\r\n        && userId == request.auth.uid\r\n        && request.resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    match /userProfiles/{userId} {\r\n      allow read: if signedIn();\r\n\r\n      allow create, update: if signedIn()\r\n        && userId == request.auth.uid\r\n        && request.resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    match /competitionRooms/{roomId} {\r\n      allow read: if signedIn();\n\n      allow create: if signedIn()\n        && request.resource.data.hostAuthId == request.auth.uid\n        && request.resource.data.status == \"waiting\";\n\r\n      allow update: if signedIn()\r\n        && (roomParticipant() || validWaitingRoomJoin());\r\n\r\n      allow delete: if signedIn()\n        && ((\"hostAuthId\" in resource.data\n            && resource.data.hostAuthId == request.auth.uid)\n          || resource.data.hostId == request.auth.uid);\n    }\r\n\r\n    match /competitionLeaderboard/{userId} {\r\n      allow read: if signedIn();\r\n\r\n      allow create, update: if signedIn()\r\n        && userId == request.auth.uid\r\n        && request.resource.data.playerId == request.auth.uid;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-06-20T14:18:33.016079Z","metadata":{"services":["cloud.firestore"]}}
