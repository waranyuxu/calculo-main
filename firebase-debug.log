[debug] [2026-06-20T13:24:58.175Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/calculo-65308/rulesets {"name":"projects/calculo-65308/rulesets/ce0e296c-ee2b-4822-b7b1-6c03fea57ad6","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    function signedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function roomParticipant() {\r\n      return signedIn()\r\n        && (resource.data.hostId == request.auth.uid\r\n          || resource.data.guestId == request.auth.uid);\r\n    }\r\n\r\n    function validWaitingRoomJoin() {\r\n      return signedIn()\r\n        && resource.data.status == \"waiting\"\r\n        && resource.data.hostId != request.auth.uid\r\n        && request.resource.data.hostId == resource.data.hostId\r\n        && request.resource.data.guestId == request.auth.uid\r\n        && request.resource.data.status == \"playing\";\r\n    }\r\n\r\n    match /mathProgress/{userId} {\r\n      allow read, write: if signedIn() && request.auth.uid == userId;\r\n    }\r\n\r\n    match /learningStates/{userId} {\r\n      allow read: if signedIn() && request.auth.uid == userId;\r\n\r\n      allow create, update: if signedIn()\r\n        && userId == request.auth.uid\r\n        && request.resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    match /userProfiles/{userId} {\r\n      allow read: if signedIn();\r\n\r\n      allow create, update: if signedIn()\r\n        && userId == request.auth.uid\r\n        && request.resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    match /competitionRooms/{roomId} {\r\n      allow read: if signedIn();\r\n\r\n      allow create: if signedIn()\r\n        && request.resource.data.hostId == request.auth.uid\r\n        && request.resource.data.status == \"waiting\";\r\n\r\n      allow update: if signedIn()\r\n        && (roomParticipant() || validWaitingRoomJoin());\r\n\r\n      allow delete: if signedIn() && resource.data.hostId == request.auth.uid;\r\n    }\r\n\r\n    match /competitionLeaderboard/{userId} {\r\n      allow read: if signedIn();\r\n\r\n      allow create, update: if signedIn()\r\n        && userId == request.auth.uid\r\n        && request.resource.data.playerId == request.auth.uid;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-06-20T13:24:58.014559Z","metadata":{"services":["cloud.firestore"]}}
